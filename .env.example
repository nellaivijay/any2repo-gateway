# Any2Repo-Gateway Environment Variables

# ── General ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── Tenant Auth ──────────────────────────────────────────────────────────
# Comma-separated valid API keys. Empty = no API key enforcement.
API_KEYS=

# ── State Store ──────────────────────────────────────────────────────────
# Backend for persistent job and tenant state.
# Options: "memory" (dev/test, default), "firestore" (GCP production)
STORE_BACKEND=memory

# ── GCP / Vertex AI ─────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
# Leave empty when using Workload Identity Federation (preferred)
GOOGLE_APPLICATION_CREDENTIALS=

# ── GCS Artifact Bucket ─────────────────────────────────────────────────
# Engines upload zipped repos to this bucket.  The gateway generates
# pre-signed URLs pointing here for customer download.
GCS_ARTIFACT_BUCKET=
# Pre-signed URL lifetime in seconds (default 15 minutes)
PRESIGNED_URL_TTL=900

# ── AWS / Bedrock ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# IAM Role ARN for Workload Identity Federation (GCP -> AWS)
AWS_ROLE_ARN=
# Auto-populated by the gateway when using WIF
AWS_WEB_IDENTITY_TOKEN_FILE=

# ── Azure / Azure ML ────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=
AZURE_REGION=eastus

# ── On-Prem ─────────────────────────────────────────────────────────────
# HTTP endpoint for an already-running engine (e.g. http://engine:8080)
ON_PREM_ENDPOINT=
# Docker network name for container-mode execution
ON_PREM_DOCKER_NETWORK=any2repo

# ── Engine Defaults ──────────────────────────────────────────────────────
DEFAULT_ENGINE=research2repo
JOB_TTL_HOURS=72
# Directory containing engine-manifest.json files for plugin discovery
ENGINE_MANIFESTS_DIR=

# ── Webhook Security ────────────────────────────────────────────────────
# HMAC-SHA256 secret for verifying engine webhook signatures.
# When set, the gateway rejects any webhook missing a valid
# X-Webhook-Signature header.
WEBHOOK_SECRET=
