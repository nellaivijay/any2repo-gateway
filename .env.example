# Any2Repo-Gateway Environment Variables

# ── General ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── Tenant Auth ──────────────────────────────────────────────────────────
# Comma-separated valid API keys. Empty = no API key enforcement.
API_KEYS=

# ── GCP / Vertex AI ─────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
# Leave empty when using Workload Identity Federation (preferred)
GOOGLE_APPLICATION_CREDENTIALS=

# ── AWS / Bedrock ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# IAM Role ARN for Workload Identity Federation (GCP -> AWS)
AWS_ROLE_ARN=
# Auto-populated by the gateway when using WIF
AWS_WEB_IDENTITY_TOKEN_FILE=

# ── Azure / Azure ML ────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=
AZURE_REGION=eastus

# ── On-Prem ─────────────────────────────────────────────────────────────
# HTTP endpoint for an already-running engine (e.g. http://engine:8080)
ON_PREM_ENDPOINT=
# Docker network name for container-mode execution
ON_PREM_DOCKER_NETWORK=any2repo

# ── Engine Defaults ──────────────────────────────────────────────────────
DEFAULT_ENGINE=research2repo
JOB_TTL_HOURS=72
# Directory containing engine-manifest.json files for plugin discovery
ENGINE_MANIFESTS_DIR=
